{
  "name": "vaporjawn-github-io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --format stylish --report-unused-disable-directives --max-warnings 4",
    "lint:fix": "eslint . --fix --format stylish --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "npm run build && npm run format:check && npm run lint && npm run test:cov",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "verify-sign": "git log -1 --show-signature",
    "fetch:contribs": "node scripts/fetch-contribs.mjs",
    "fetch:contribs:local": "GITHUB_LOGIN=vaporjawn node scripts/fetch-contribs.mjs",
    "generate:rss": "node scripts/generate-rss.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@hookform/resolvers": "^5.4.0",
    "@material/web": "^2.4.1",
    "@mdx-js/rollup": "^3.1.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@sentry/react": "^10.65.0",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/react-md-editor": "^4.0.11",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "firebase": "^12.15.0",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "react": "^19.2.7",
    "react-calendly": "^4.4.0",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/eslint": "^9.6.1",
    "@types/eslint__js": "^9.14.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-transform-stub": "^2.0.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "ws": "^8.21.0",
    "rollup": "^4.62.2",
    "postcss": "^8.5.16",
    "minimatch": "^3.1.5",
    "yaml": "^1.10.3",
    "picomatch": "^2.3.2",
    "brace-expansion": "^1.1.13"
  }
}
